{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventsListResult",
  "type": "object",
  "required": [
    "events"
  ],
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/EventDto"
      }
    },
    "next_after_seq": {
      "type": [
        "integer",
        "null"
      ],
      "format": "int64"
    }
  },
  "definitions": {
    "EventDto": {
      "type": "object",
      "required": [
        "event_type",
        "id",
        "payload",
        "recorded_at",
        "seq"
      ],
      "properties": {
        "event_type": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "payload": true,
        "recorded_at": {
          "type": "string"
        },
        "repository_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "seq": {
          "type": "integer",
          "format": "int64"
        },
        "session_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "snapshot_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "worktree_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}