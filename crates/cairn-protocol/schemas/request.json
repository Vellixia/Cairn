{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Request",
  "description": "One request line on the IPC channel (JSON-lines framing).",
  "type": "object",
  "required": [
    "id",
    "method"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "method": {
      "type": "string"
    },
    "params": {
      "default": null
    }
  }
}