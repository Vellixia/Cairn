{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SessionStartParams",
  "type": "object",
  "required": [
    "agent_instance_id",
    "agent_type"
  ],
  "properties": {
    "agent_instance_id": {
      "type": "string",
      "format": "uuid"
    },
    "agent_pid": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint32",
      "minimum": 0.0
    },
    "agent_type": {
      "type": "string"
    },
    "path": {
      "type": [
        "string",
        "null"
      ]
    },
    "repository_id": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}