# Cairn configuration — copy to `.env` (project) or ~/.config/cairn/.env (machine-global).
# Precedence: real environment variables > project .env > global .env > built-in defaults.

# --- server ---
# CAIRN_DATA_DIR=/data          # where Cairn keeps its data (default: OS data dir, /data in Docker)
# CAIRN_HOST=127.0.0.1          # serve bind host (use 0.0.0.0 to expose on a network/server)
# CAIRN_PORT=7777               # serve bind port
# CAIRN_SECRET_KEY=             # 32+ byte HS256 key for signing device-token JWTs. MUST be set for
#                               # production; the in-container `cairn-server` requires it for
#                               # minting device tokens + session cookies.

# --- admin (env-only bootstrap) ---
# On the first boot of a fresh data volume, the cairn container reads these two vars and mints
# the admin record automatically. After the record exists, these are ignored — rotate the password
# via the dashboard /you/settings page (or wipe the data volume with `docker compose down -v`).
#
# To opt out of env-only bootstrap and let the dashboard /setup wizard prompt for credentials
# on first visit, comment out CAIRN_ADMIN_PASSWORD (and leave CAIRN_ADMIN_USERNAME as-is or remove).
CAIRN_ADMIN_USERNAME=admin
CAIRN_ADMIN_PASSWORD=CHANGEME_admin_password_at_least_8_chars
# CAIRN_TLS_CERT=/path/to/fullchain.pem   # PEM cert chain. REQUIRED when CAIRN_HOST binds to a
# CAIRN_TLS_KEY=/path/to/privkey.pem      # non-loopback address (0.0.0.0, a LAN IP, a DNS name);
#                                         # the in-container server refuses to start in cleartext
#                                         # HTTP on a network-exposed bind. Both vars must be set
#                                         # together.
# CAIRN_CORS_ORIGINS=                     # comma-separated allowed CORS origins (default: same-origin
#                                         # only). Wildcard ("*") is REJECTED — list explicit origins.
#                                         # Example: http://localhost:3000,https://dashboard.example.com
# CAIRN_WORKSPACE_ROOT=                   # restrict file reads/writes to this directory (path traversal guard)

# --- logging ---
# RUST_LOG=cairn_api=info,cairn_store=warn   # structured log level (default: warn for most crates)
#   cairn_api=info  → one line per request (method, path, status, latency via tower TraceLayer)
#   cairn_store=debug → SurrealDB query tracing
#   cairn_embed=info  → model load / embed events

# --- cairn client (the `cairn` CLI - mcp/hook/setup/doctor/status/statusline) ---
# These are read by the CLIENT binary on the machine running your AI agent, not by the
# server. Precedence is env > `~/.cairn/config.toml` > built-in default - `cairn onboard`/
# `cairn setup` write the config file for you, so most users never need to set these
# directly; they're here for advanced/CI use (e.g. exporting CAIRN_SERVER + CAIRN_TOKEN in
# a headless environment instead of passing --server/--token flags interactively).
# CAIRN_SERVER=http://your-server:7777   # default server for `cairn mcp` / `hook` / `sync` / `pull`
# CAIRN_TOKEN=                           # bearer device token (mint one via the dashboard's You > Tokens page)
# CAIRN_TIMEOUT_MS=4000                  # per-request timeout for hook/doctor/status HTTP calls
# CAIRN_DEBUG=false                      # 1/true/yes/on logs hook timing + request outcomes to
#                                        # ~/.cairn/logs/hook.log (1 MiB rotation)
# CAIRN_INJECT_CONTEXT=false             # 1/true/yes/on injects ~1k tokens of relevant memory into
#                                        # every prompt via UserPromptSubmit. `cairn onboard`/`setup`
#                                        # turn this on by default for freshly-onboarded installs;
#                                        # existing installs keep this binary default (off) unless
#                                        # they re-onboard or set it explicitly.
# CAIRN_GUARD=false                      # 1/true/yes/on opts into the PreToolUse guard (Claude Code
#                                        # only): verifies risky edits and sanitizes Bash commands
#                                        # for secrets before they run. Off by default; fails open
#                                        # (allows) if the server doesn't answer in time.

# --- datastore: SurrealDB ---
# Cairn stores data in SurrealDB. Default: ws://localhost:8000. The docker-compose stack
# overrides this to the bundled surreal service automatically (ws://surreal:8000, no host
# port - reachable only over the compose network). Point this at any reachable SurrealDB
# v3.x server (the SDK and server major versions must match - v2.x servers reject the v3.x
# client's WebSocket handshake):
# CAIRN_DB_URL=ws://your-surreal-host:8000
CAIRN_DB_USER=root
# CAIRN_DB_PASS is the same value as SURREAL_PASS below when using the bundled docker-compose
# stack - the cairn container signs in to the surreal container with these credentials.
# CAIRN_DB_TIMEOUT_SECS=10       # per-query deadline for SurrealDB (default 10 s); 0 disables

# --- docker compose stack (only read by `docker compose`, for the bundled SurrealDB) ---
# SURREAL_USER=root             # root username the bundled surreal service boots with
#
# SurrealDB root password (REQUIRED — startup guard refuses to boot with empty or a
# well-known placeholder like `root`/`secret`/`changeme`/`password`).
# Generate a strong one with:  openssl rand -base64 24
SURREAL_PASS=CHANGEME_SURREAL_PASSWORD

# --- embeddings (global "embedded LLM" for vector search) ---
# provider: local (default) | openai | ollama | hashing
#   hashing = deterministic, dependency-free feature-hashing (no model/network); used by tests and
#   handy as a zero-setup fallback, but it captures only lexical overlap, not true semantics.
CAIRN_EMBED_PROVIDER=local
# Model id; the local default is all-MiniLM-L6-v2 (384-dim, runs in-process, no API key).
# CAIRN_EMBED_MODEL=all-MiniLM-L6-v2
# For ollama / OpenAI-compatible providers:
# CAIRN_EMBED_URL=http://localhost:11434
# CAIRN_EMBED_API_KEY=sk-...

# --- session lifecycle + background jobs (v0.8.0) ---
# CAIRN_SESSION_TTL_DAYS=2              # a Session-scoped memory untouched this long promotes to Global
# CAIRN_DECAY_PERIOD_DAYS=30            # confidence half-life for the weekly memory-decay job
# CAIRN_ACCESS_LOG_RETENTION_DAYS=90    # access_log rows older than this are pruned monthly
# CAIRN_CRON_ENABLED=true               # set false to disable the in-process scheduler entirely
#                                       # (manual POST /api/cron/run/:job still works either way)

# --- LLM-driven memory intelligence (v0.8.0) ---
# Any OpenAI-compatible /v1/chat/completions endpoint (Ollama, llama.cpp server, OpenAI...).
# Off by default - concept extraction, contradiction detection, and promotion scoring all
# degrade to cheap non-LLM fallbacks (or a no-op) when this is unset.
# CAIRN_LLM_CONSOLIDATION=true
# CAIRN_LLM_CONSOLIDATION_URL=http://localhost:11434/v1/chat/completions
# CAIRN_LLM_CONSOLIDATION_MODEL=llama3.2
# CAIRN_LLM_CONSOLIDATION_API_KEY=
# CAIRN_LLM_DAILY_BUDGET=200000          # tokens/day across all background LLM calls, 0 = unlimited

# --- autopilot (v0.8.0) - all reversible via the off/manual settings below ---
# CAIRN_PROMOTE_THRESHOLD=0.85          # promo_score at/above this auto-promotes Project -> Global
# CAIRN_DEMOTE_IDLE_DAYS=45             # an auto-promoted memory unused this long auto-demotes
# CAIRN_DRIFT_AUTOPILOT=safe            # safe | off | all  (a danger-risk edit never auto-approves)
# CAIRN_DRIFT_SAFE_GLOBS=docs/**,*.md,**/tests/**,**/*.test.*
# CAIRN_AUTO_ANCHOR=true                # derive a task anchor from the first prompt when none is set

# --- resilience & self-tuning (v0.8.0) ---
# CAIRN_SELFTUNE=true                   # weekly job nudges promote_threshold from observed recall
#                                       # quality (also accepts on/off/1/0/yes/no)
# CAIRN_MAX_WORKING_PER_PROJECT=500     # per-project Working-tier cap; oldest excess is evicted
#                                       # by the memory-decay job. 0 = unlimited
