# Cairn configuration — copy to `.env` (project) or `~/.config/cairn/.env` (machine-global).
#
# Precedence (highest → lowest):
#   1. CLI flag           e.g. `cairn serve --host 0.0.0.0`, `--data-dir <path>`
#   2. Real env var       whatever's already in your shell
#   3. Project `.env`     `<repo>/.env` (or `docker compose`'s `environment:` block)
#   4. Global `.env`      `~/.config/cairn/.env` (Linux) / `%APPDATA%\cairn\.env` (Windows)
#   5. Built-in default   hard-coded fallback in `cairn-core/src/config.rs`
#
# `.env` files are loaded by `cairn-cli` at startup via `dotenvy` (see
# `crates/cairn-cli/src/main.rs`). `dotenvy` only fills variables that are not
# already set, so real env always wins over a project `.env`, and a project
# `.env` always wins over the global one. Lines starting with `#` are
# comments; uncomment to set a value.

# -----------------------------------------------------------------------------
# server
# -----------------------------------------------------------------------------
# CAIRN_DATA_DIR=/data          # where Cairn keeps its data (default: OS data dir, /data in Docker)
# CAIRN_HOST=127.0.0.1          # serve bind host (use 0.0.0.0 / a LAN IP to expose on a network)
# CAIRN_PORT=7777               # serve bind port (default: 7777)

# -----------------------------------------------------------------------------
# connecting a personal device to a server
# -----------------------------------------------------------------------------
# CAIRN_SERVER=http://your-server:7777   # default server for `cairn sync` / `pull` / `contribute`

# -----------------------------------------------------------------------------
# datastore (required: HelixDB)
# -----------------------------------------------------------------------------
# Cairn stores data in HelixDB. The docker-compose stack wires the cairn container to its bundled
# Helix automatically (http://helix:8080). For a standalone `cairn serve`, point this at a HelixDB
# server (required — `cairn serve` errors without it):
# CAIRN_HELIX_URL=http://your-helix-host:6969
# CAIRN_HELIX_NS=cairn_          # label-namespace prefix on the Helix backend. Lets multiple
#                                # Cairn instances (or isolated tests) share one Helix server
#                                # without colliding. Default: `cairn_`. Only override if you
#                                # run multiple Cairn instances against the same Helix.

# -----------------------------------------------------------------------------
# embeddings (the "embedded LLM" for vector search)
# -----------------------------------------------------------------------------
# provider: local (default) | openai | ollama | hashing
#   hashing = deterministic, dependency-free feature-hashing (no model/network); used by tests and
#   handy as a zero-setup fallback, but it captures only lexical overlap, not true semantics.
CAIRN_EMBED_PROVIDER=local
# Model id; the local default is all-MiniLM-L6-v2 (384-dim, runs in-process, no API key).
# CAIRN_EMBED_MODEL=all-MiniLM-L6-v2
# For ollama / OpenAI-compatible providers:
# CAIRN_EMBED_URL=http://localhost:11434
# CAIRN_EMBED_API_KEY=sk-...

# -----------------------------------------------------------------------------
# self-update (`cairn update`)
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=***            # optional. Lifts GitHub's unauthenticated API rate limit and is
# CAIRN_GITHUB_TOKEN=***      # required for private mirrors. CAIRN_GITHUB_TOKEN takes
#                             # precedence if both are set. The token never leaves your
#                             # machine; `cairn update` uses it only for the version check.

# -----------------------------------------------------------------------------
# docker compose stack (only read by `docker compose`, for the bundled Helix + MinIO)
# -----------------------------------------------------------------------------
# HELIX_PORT=6969               # host port for direct HelixDB access (maps to container :8080)
# MINIO_ROOT_USER=minioadmin    # credentials for the bundled MinIO that Helix persists to
# MINIO_ROOT_PASSWORD=minioadmin

# -----------------------------------------------------------------------------
# install script (`curl … | sh`) — only honored by scripts/install.sh and scripts/install.ps1
# -----------------------------------------------------------------------------
# CAIRN_REPO=YourFork/Cairn            # override the GitHub repo to install from
#                                      # (default: Vellixia/Cairn)
# CAIRN_INSTALL_DIR=$HOME/.local/bin   # install location
#                                      # (default: ~/.local/bin on Linux/macOS,
#                                      # $env:LOCALAPPDATA\Cairn\bin on Windows)
