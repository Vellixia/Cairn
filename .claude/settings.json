{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "cairn-cli hook PostToolUse",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|MultiEdit|NotebookEdit"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "cairn-cli hook SessionEnd",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "cairn-cli hook SessionStart",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "cairn-cli hook UserPromptSubmit",
            "type": "command"
          }
        ]
      }
    ]
  }
}
